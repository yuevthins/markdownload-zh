{
  "name": "markdownload-zh",
  "version": "0.1.0",
  "description": "将网页内容剪藏为 Markdown 文件，专为 Obsidian 用户优化",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "test": "vitest",
    "test:integration": "vitest run tests/integration/",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --config=tests/e2e/playwright.config.ts --headed",
    "fetch-fixtures": "npx tsx scripts/fetch-fixtures.ts",
    "fetch-fixtures:browser": "npx tsx scripts/fetch-fixtures-playwright.ts",
    "fetch-fixtures:browser:headed": "npx tsx scripts/fetch-fixtures-playwright.ts --headed",
    "test:extraction": "npx tsx scripts/run-extraction-tests.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write ."
  },
  "keywords": [
    "chrome-extension",
    "markdown",
    "obsidian",
    "web-clipper"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "wxt": "^0.20.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/jsdom": "^27.0.0",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.4.0",
    "playwright": "^1.58.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
